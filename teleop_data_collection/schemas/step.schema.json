{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "teleop_vla aligned step",
  "type": "object",
  "required": [
    "step_idx",
    "timestamp_ns",
    "step_time_s",
    "rgb_path",
    "depth_path",
    "qpos",
    "ee_pose"
  ],
  "properties": {
    "step_idx": {"type": "integer"},
    "timestamp_ns": {"type": "integer"},
    "step_time_s": {"type": "number"},
    "frame_number": {"type": "integer"},
    "camera_timestamp_ms": {"type": "number"},
    "camera_frame_age_s": {"type": ["number", "null"]},
    "sample_source": {"type": ["string", "null"]},
    "rgb_path": {"type": ["string", "null"]},
    "depth_path": {"type": ["string", "null"]},
    "rgb_vis_path": {"type": ["string", "null"]},
    "camera_paths": {"type": ["object", "null"]},
    "point_cloud_npz_path": {"type": ["string", "null"]},
    "rgb_sha256": {"type": "string"},
    "depth_sha256": {"type": "string"},
    "rgb_vis_sha256": {"type": ["string", "null"]},
    "point_cloud_npz_sha256": {"type": ["string", "null"]},
    "qpos": {"type": "array", "items": {"type": "number"}},
    "qvel": {"type": "array", "items": {"type": "number"}},
    "tau": {"type": "array", "items": {"type": "number"}},
    "ee_pose": {"type": "array", "items": {"type": "number"}},
    "ee_twist": {"type": ["array", "null"]},
    "gripper_target": {"type": ["number", "null"]},
    "gripper_actual": {"type": ["number", "null"]},
    "gripper_vel": {"type": ["number", "null"]},
    "joint_enabled": {"type": ["array", "null"], "items": {"type": "boolean"}},
    "joint_faults": {"type": ["array", "null"], "items": {"type": "number"}},
    "joint_mode_states": {"type": ["array", "null"], "items": {"type": "number"}},
    "motor_states": {"type": "object"},
    "can": {"type": "object"},
    "robot_status": {"type": "object"},
    "teleop_command": {"type": "object"},
    "control_command": {"type": "object"},
    "executed_command": {"type": "object"},
    "action_joint_delta": {"type": ["array", "null"]},
    "action_ee_delta": {"type": ["array", "null"]},
    "action_gripper_delta": {"type": ["number", "null"]},
    "action_space": {"type": ["string", "null"]},
    "action_source": {"type": ["string", "null"]},
    "policy_state": {"type": ["object", "null"]},
    "observation": {"type": ["object", "null"]},
    "pico_seq": {"type": ["integer", "null"]},
    "pico_received_at": {"type": ["string", "null"]},
    "pico_pose": {"type": ["object", "null"]},
    "pico_buttons": {"type": ["object", "null"]},
    "pico_axes": {"type": ["object", "null"]},
    "pico_viewer": {"type": ["object", "null"]},
    "pico_raw": {"type": ["object", "null"]},
    "raw_cameras": {"type": ["object", "null"]},
    "collision_flag": {"type": ["boolean", "null"]},
    "contact_flag": {"type": ["boolean", "null"]},
    "annotation_id": {"type": ["string", "null"]},
    "quality": {"type": ["object", "null"]}
  }
}
